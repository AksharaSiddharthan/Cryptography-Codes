#include <iostream>
using namespace std;

int gcd(int a,int b){
    return b==0 ? a : gcd(b,a%b);
}

long long power(long long b,long long e,long long m){
    long long r=1;
    for(int i=0;i<e;i++)
        r=(r*b)%m;
    return r;
}

int main(){
    int p,q;
    cout<<"Enter p and q: ";
    cin>>p>>q;

    int n=p*q, phi=(p-1)*(q-1);

    int e;
    for(e=2;e<phi;e++)
        if(gcd(e,phi)==1) break;

    int d;
    for(d=1;d<phi;d++)
        if((d*e)%phi==1) break;

    cout<<"\nPublic Key: ("<<e<<","<<n<<")";
    cout<<"\nPrivate Key: ("<<d<<","<<n<<")";

    int pt;
    cout<<"\nEnter Plaintext: ";
    cin>>pt;

    long long ct=power(pt,e,n);
    cout<<"Ciphertext: "<<ct;

    cout<<"\nDecrypted: "<<power(ct,d,n);
}

