#include <iostream>
using namespace std;

int mod26(int x) { 
    return (x % 26 + 26) % 26; }

int modInverse(int a) {
    a = mod26(a);
    for (int i = 1; i < 26; i++)
        if (mod26(a * i) == 1) 
            return i;
    return -1;
}

int main() {
    string pt, ct = "", dt = "";
    int k[3][3], inv[3][3];

    cout << "Enter plaintext: ";
    cin >> pt;

    for (char &c : pt) c = tolower(c);
    while (pt.length() % 3 != 0) 
        pt += 'x';

    cout << "Enter 3x3 key matrix:\n";
    for (int i = 0; i < 3; i++)
        for (int j = 0; j < 3; j++)
            cin >> k[i][j];

    // -------- Encryption --------
    for (int i = 0; i < pt.length(); i += 3)
        for (int r = 0; r < 3; r++) {
            int sum = 0;
            for (int c = 0; c < 3; c++)
                sum += k[r][c] * (pt[i + c] - 'a');
            ct += char(mod26(sum) + 'a');
        }

    cout << "Ciphertext: " << ct << endl;

    // -------- Determinant --------
    int det =
        k[0][0]*(k[1][1]*k[2][2]-k[1][2]*k[2][1])
      - k[0][1]*(k[1][0]*k[2][2]-k[1][2]*k[2][0])
      + k[0][2]*(k[1][0]*k[2][1]-k[1][1]*k[2][0]);

    int detInv = modInverse(det);
    if (detInv == -1) {
        cout << "Key not invertible!";
        return 0;
    }

    // -------- Adjoint Matrix --------
    inv[0][0]= k[1][1]*k[2][2]-k[1][2]*k[2][1];
    inv[0][1]=-(k[0][1]*k[2][2]-k[0][2]*k[2][1]);
    inv[0][2]= k[0][1]*k[1][2]-k[0][2]*k[1][1];

    inv[1][0]=-(k[1][0]*k[2][2]-k[1][2]*k[2][0]);
    inv[1][1]= k[0][0]*k[2][2]-k[0][2]*k[2][0];
    inv[1][2]=-(k[0][0]*k[1][2]-k[0][2]*k[1][0]);

    inv[2][0]= k[1][0]*k[2][1]-k[1][1]*k[2][0];
    inv[2][1]=-(k[0][0]*k[2][1]-k[0][1]*k[2][0]);
    inv[2][2]= k[0][0]*k[1][1]-k[0][1]*k[1][0];

    // Multiply adjoint with determinant inverse
    for (int i = 0; i < 3; i++)
        for (int j = 0; j < 3; j++)
            inv[i][j] = mod26(inv[i][j] * detInv);

    // -------- Decryption --------
    for (int i = 0; i < ct.length(); i += 3)
        for (int r = 0; r < 3; r++) {
            int sum = 0;
            for (int c = 0; c < 3; c++)
                sum += inv[r][c] * (ct[i + c] - 'a');
            dt += char(mod26(sum) + 'a');
        }

    cout << "Decrypted Text: " << dt;
}

